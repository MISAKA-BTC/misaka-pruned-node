{
  "name": "misaka-network",
  "version": "0.1.0",
  "description": "Misaka Network - Transfer-only privacy-enhanced L1 blockchain",
  "main": "dist/index.js",
  "bin": {
    "misaka": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli/index.js",
    "test": "jest --forceExit --detectOpenHandles",
    "test:unit": "jest --testPathPattern='tests/unit' --forceExit",
    "test:integration": "jest --testPathPattern='tests/integration' --forceExit --detectOpenHandles",
    "dev": "ts-node src/cli/index.ts",
    "node:start": "ts-node src/cli/index.ts node start",
    "demo": "bash scripts/demo.sh"
  },
  "dependencies": {
    "@noble/curves": "^1.8.1",
    "@types/elliptic": "^6.4.18",
    "bech32": "^2.0.0",
    "commander": "^12.0.0",
    "elliptic": "^6.6.1",
    "level": "^8.0.1",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  }
}
